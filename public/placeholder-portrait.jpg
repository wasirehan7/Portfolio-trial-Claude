<svg xmlns="http://www.w3.org/2000/svg" width="520" height="700" viewBox="0 0 520 700">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2332"/>
      <stop offset="100%" style="stop-color:#0d1821"/>
    </linearGradient>
    <linearGradient id="skin" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#c49a6c"/>
      <stop offset="100%" style="stop-color:#a07850"/>
    </linearGradient>
    <linearGradient id="shirt" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#2a3a4a"/>
      <stop offset="100%" style="stop-color:#1a2a3a"/>
    </linearGradient>
  </defs>
  <rect width="520" height="700" fill="url(#bg)"/>
  <!-- subtle grid -->
  <line x1="0" y1="350" x2="520" y2="350" stroke="#D7E2EA" stroke-opacity="0.04" stroke-width="1"/>
  <line x1="260" y1="0" x2="260" y2="700" stroke="#D7E2EA" stroke-opacity="0.04" stroke-width="1"/>
  <!-- body / suit -->
  <path d="M100 700 L100 480 Q130 440 160 430 Q200 460 260 465 Q320 460 360 430 Q390 440 420 480 L420 700 Z" fill="url(#shirt)"/>
  <!-- neck -->
  <rect x="228" y="340" width="64" height="95" rx="8" fill="url(#skin)"/>
  <!-- head -->
  <ellipse cx="260" cy="300" rx="90" ry="105" fill="url(#skin)"/>
  <!-- hair -->
  <ellipse cx="260" cy="210" rx="90" ry="55" fill="#1a1005"/>
  <rect x="170" y="210" width="24" height="70" rx="12" fill="#1a1005"/>
  <rect x="326" y="210" width="24" height="70" rx="12" fill="#1a1005"/>
  <!-- eyes -->
  <ellipse cx="228" cy="295" rx="14" ry="10" fill="white"/>
  <ellipse cx="292" cy="295" rx="14" ry="10" fill="white"/>
  <ellipse cx="230" cy="296" rx="7" ry="7" fill="#1a1005"/>
  <ellipse cx="294" cy="296" rx="7" ry="7" fill="#1a1005"/>
  <!-- eyebrows -->
  <path d="M214 278 Q228 272 242 278" stroke="#1a1005" stroke-width="3" fill="none" stroke-linecap="round"/>
  <path d="M278 278 Q292 272 306 278" stroke="#1a1005" stroke-width="3" fill="none" stroke-linecap="round"/>
  <!-- nose -->
  <path d="M256 300 Q248 322 258 332 Q262 334 260 332 Q268 334 262 322 Z" fill="#a07850" opacity="0.5"/>
  <!-- mouth -->
  <path d="M238 352 Q260 364 282 352" stroke="#8a5a3a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
  <!-- collar -->
  <path d="M200 430 L240 480 L260 465 L280 480 L320 430" stroke="#3a4a5a" stroke-width="2" fill="none"/>
  <!-- label -->
  <text x="260" y="665" font-family="Kanit, sans-serif" font-size="13" fill="#D7E2EA" opacity="0.35" text-anchor="middle" letter-spacing="3">PORTRAIT PHOTO</text>
</svg>
