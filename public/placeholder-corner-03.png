  <ellipse cx="110" cy="110" rx="60" ry="35" stroke="#D7E2EA" stroke-opacity="0.12" stroke-width="1" fill="none"/>
  <ellipse cx="110" cy="110" rx="40" ry="22" stroke="#D7E2EA" stroke-opacity="0.14" stroke-width="1" fill="none"/>
