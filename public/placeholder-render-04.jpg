<svg xmlns="http://www.w3.org/2000/svg" width="420" height="270" viewBox="0 0 420 270">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a0a2a"/>
      <stop offset="50%" style="stop-color:#3a1a5c"/>
      <stop offset="100%" style="stop-color:#5a3a7a"/>
    </linearGradient>
  </defs>
  <rect width="420" height="270" fill="url(#g)" rx="16"/>
  <!-- horizon line -->
  <line x1="0" y1="160" x2="420" y2="160" stroke="#D7E2EA" stroke-opacity="0.08" stroke-width="1"/>
  <!-- contour lines -->
  <path d="M0 180 Q105 165 210 175 Q315 185 420 170" stroke="#D7E2EA" stroke-opacity="0.06" stroke-width="1" fill="none"/>
  <path d="M0 195 Q105 182 210 190 Q315 200 420 185" stroke="#D7E2EA" stroke-opacity="0.05" stroke-width="1" fill="none"/>
  <!-- tree silhouettes -->
  <rect x="30" y="120" width="6" height="40" fill="#D7E2EA" opacity="0.07"/>
  <ellipse cx="33" cy="118" rx="14" ry="20" fill="#D7E2EA" opacity="0.07"/>
  <rect x="370" y="130" width="5" height="30" fill="#D7E2EA" opacity="0.07"/>
  <ellipse cx="372" cy="128" rx="11" ry="16" fill="#D7E2EA" opacity="0.07"/>
  <!-- label -->
  <text x="210" y="243" font-family="Kanit, sans-serif" font-size="11" fill="#D7E2EA" opacity="0.25" text-anchor="middle" letter-spacing="3">RENDER 4</text>
</svg>
